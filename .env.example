# ─────────────────────────────────────────────────
#  WORKLOG BACKEND — Environment Variables
# ─────────────────────────────────────────────────

# MongoDB Atlas connection string
# Replace <username>, <password>, and <cluster> with your actual values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/worklog?retryWrites=true&w=majority

# JWT Secret — use a long, random string in production
JWT_SECRET=change_this_to_a_very_long_random_secret_string_in_production

# Server port
PORT=5000

# Frontend origin for CORS (no trailing slash)
CLIENT_ORIGIN=http://localhost:3000
